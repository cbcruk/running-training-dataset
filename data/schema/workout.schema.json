{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rtd/workout.schema.json",
  "title": "Running Workout",
  "description": "A normalized physiological workout entity. Naming is NOT stored here - see usage.schema.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "canonical_name",
    "family",
    "status",
    "structure",
    "intensity",
    "target_adaptation",
    "venue",
    "claim",
    "test",
    "placement",
    "instructions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Descriptive, system-neutral. NEVER a colloquial name like 'tempo-run'."
    },
    "canonical_name": {
      "type": "string",
      "description": "Descriptive English. Not what any coach calls it."
    },
    "family": {
      "enum": [
        "easy",
        "recovery",
        "long",
        "threshold",
        "vo2max",
        "speed",
        "hill",
        "fartlek",
        "race-pace"
      ]
    },
    "status": {
      "enum": ["draft", "verified"],
      "description": "draft = citations unverified by a human. Nothing ships verified without L4 human commit."
    },
    "target_adaptation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "plasma-volume",
          "capillarization",
          "mitochondrial-density",
          "stroke-volume",
          "lactate-clearance",
          "mlss-shift",
          "vo2max",
          "running-economy",
          "neuromuscular-recruitment",
          "glycogen-storage",
          "fat-oxidation",
          "tendon-stiffness",
          "bone-density",
          "musculoskeletal-durability",
          "pacing-skill"
        ]
      },
      "description": "Primary filter axis. Maps to exercises-dataset's body_part."
    },
    "venue": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["track", "road-flat", "road-rolling", "hill", "treadmill", "trail", "grass", "any"]
      },
      "description": "Maps to exercises-dataset's equipment. 'No track' filters like 'no barbell'."
    },
    "placement": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["base", "build", "peak", "taper", "offseason"] }
    },
    "structure": { "$ref": "#/$defs/structure" },
    "intensity": { "$ref": "#/$defs/intensity" },
    "claim": { "$ref": "#/$defs/claim" },
    "test": { "$ref": "#/$defs/test" },
    "prerequisites": { "$ref": "#/$defs/prerequisites" },
    "safety": { "$ref": "#/$defs/safety" },
    "common_errors": { "type": "array", "items": { "$ref": "#/$defs/i18n" } },
    "instructions": { "$ref": "#/$defs/i18n" },
    "attribution": {
      "type": ["string", "null"],
      "description": "Who formalized it. null = folk/unattributable."
    }
  },

  "$defs": {
    "i18n": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ko", "en"],
      "properties": { "ko": { "type": "string" }, "en": { "type": "string" } }
    },

    "quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit"],
      "properties": {
        "value": { "type": "number", "exclusiveMinimum": 0 },
        "min": { "type": "number", "exclusiveMinimum": 0 },
        "max": { "type": "number", "exclusiveMinimum": 0 },
        "unit": {
          "enum": ["s", "m"],
          "description": "SI only. Renderers convert. Unit drift is the #1 bug class."
        }
      },
      "oneOf": [{ "required": ["value"] }, { "required": ["min", "max"] }]
    },

    "count": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": { "type": "integer", "minimum": 1 },
        "min": { "type": "integer", "minimum": 1 },
        "max": { "type": "integer", "minimum": 1 }
      },
      "oneOf": [{ "required": ["value"] }, { "required": ["min", "max"] }]
    },

    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tier"],
      "properties": {
        "tier": {
          "enum": ["consensus", "plausible", "tradition"],
          "description": "consensus = textbook. plausible = studied, contested. tradition = everyone does it, nobody knows."
        },
        "cite": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "note": { "$ref": "#/$defs/i18n" }
      },
      "allOf": [
        {
          "if": {
            "required": ["tier"],
            "properties": { "tier": { "enum": ["consensus", "plausible"] } }
          },
          "then": { "required": ["cite"] }
        },
        {
          "if": { "required": ["tier"], "properties": { "tier": { "const": "tradition" } } },
          "then": {
            "not": { "required": ["cite"] },
            "description": "A tradition-tier claim MUST NOT carry a citation. If you have one, it is not tradition."
          }
        }
      ]
    },

    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["warmup", "work", "recovery", "cooldown", "repeat"] },
        "count": { "$ref": "#/$defs/count" },
        "children": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/segment" } },
        "duration": { "$ref": "#/$defs/quantity" },
        "distance": { "$ref": "#/$defs/quantity" },
        "intensity_ref": {
          "type": "string",
          "description": "'self' = this workout's own intensity block. Otherwise a workout id (e.g. 'easy-run')."
        },
        "ramp_to": {
          "type": "string",
          "description": "intensity_ref to progress toward across this segment"
        },
        "note": { "$ref": "#/$defs/i18n" }
      },
      "if": { "required": ["kind"], "properties": { "kind": { "const": "repeat" } } },
      "then": { "required": ["count", "children"] },
      "else": {
        "required": ["intensity_ref"],
        "oneOf": [{ "required": ["duration"] }, { "required": ["distance"] }]
      }
    },

    "structure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["segments"],
      "properties": {
        "segments": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/segment" } },
        "stochastic": {
          "type": "boolean",
          "description": "true = segments are illustrative only (fartlek). Renderer must not imply precision."
        }
      }
    },

    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "confidence"],
      "properties": {
        "model": {
          "enum": [
            "daniels-vdot",
            "pct_hrmax",
            "pct_hrr",
            "pct_vo2max",
            "pct_cs",
            "rpe_10",
            "lactate_mmol",
            "race_pace_ref"
          ]
        },
        "zone": { "type": "string" },
        "value": { "type": ["number", "string"] },
        "range": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } },
        "confidence": {
          "enum": ["exact", "approx", "rough"],
          "description": "exact = definitional within its model. approx/rough = loose cross-model mapping."
        },
        "note": { "$ref": "#/$defs/i18n" }
      },
      "oneOf": [{ "required": ["zone"] }, { "required": ["value"] }, { "required": ["range"] }]
    },

    "intensity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchors"],
      "properties": {
        "primary_anchor": { "type": "string" },
        "anchors": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/anchor" },
          "contains": { "required": ["model"], "properties": { "model": { "const": "rpe_10" } } },
          "minContains": 1,
          "maxContains": 1,
          "description": "minItems 2: a single anchor hides that anchors disagree. Exactly one rpe_10 is mandatory - it is the only anchor requiring no equipment, no test, no model, and no system membership, therefore the only universal exchange currency between systems and the only renderable axis. maxContains 1 keeps the renderer deterministic."
        }
      }
    },

    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposition", "mechanism", "evidence"],
      "description": "A falsifiable proposition, not a guide. `test` is the procedure that would falsify `proposition`.",
      "properties": {
        "proposition": {
          "$ref": "#/$defs/i18n",
          "description": "One sentence, falsifiable. 'Doing X shifts Y.' Not 'X is good for Y.'"
        },
        "mechanism": { "$ref": "#/$defs/i18n" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },

    "confound": {
      "type": "object",
      "additionalProperties": false,
      "required": ["factor", "severity", "note"],
      "properties": {
        "factor": { "type": "string" },
        "severity": { "enum": ["low", "moderate", "high"] },
        "shares_mechanism": {
          "type": "boolean",
          "description": "true = acts through the SAME physiology as the claim, therefore inseparable by observation alone. The worst kind: not noise, but indistinguishable."
        },
        "note": { "$ref": "#/$defs/i18n" }
      }
    },

    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detectable", "evidence"],
      "description": "NOT effect size. A falsification procedure: what you would observe if the claim holds, when, what could fake it, and what a null means.",
      "properties": {
        "detectable": { "type": "boolean" },
        "what": { "$ref": "#/$defs/i18n" },
        "when_weeks": { "$ref": "#/$defs/count" },
        "mechanism": { "$ref": "#/$defs/i18n" },
        "confounds": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/confound" },
          "description": "minItems 1 is a forcing function. Every real-world signal has at least one confound; if you cannot name one you have not looked."
        },
        "if_absent": {
          "$ref": "#/$defs/i18n",
          "description": "What a null result means. Without this the claim is unfalsifiable, i.e. not a claim."
        },
        "evidence": { "$ref": "#/$defs/evidence" }
      },
      "if": { "required": ["detectable"], "properties": { "detectable": { "const": true } } },
      "then": { "required": ["what", "when_weeks", "confounds", "if_absent"] },
      "else": {
        "not": {
          "anyOf": [
            { "required": ["what"] },
            { "required": ["when_weeks"] },
            { "required": ["confounds"] },
            { "required": ["if_absent"] }
          ]
        },
        "description": "detectable:false MUST NOT claim a signal, a timeline, confounds, or a null interpretation. An unobservable null cannot be interpreted."
      }
    },

    "prerequisites": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_weekly_volume_km": { "type": "number" },
        "min_training_age_months": { "type": "number" },
        "requires_workouts": { "type": "array", "items": { "type": "string" } },
        "evidence": { "$ref": "#/$defs/evidence" },
        "note": { "$ref": "#/$defs/i18n" }
      }
    },

    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["injury_risk"],
      "properties": {
        "injury_risk": { "enum": ["low", "moderate", "high"] },
        "note": { "$ref": "#/$defs/i18n" }
      }
    }
  }
}
