{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rtd/system.schema.json",
  "title": "Training System",
  "description": "The browsing entity. A system is a bet plus the cost of taking it, not a plan.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "status",
    "intensity_model",
    "bet",
    "philosophy",
    "commitment",
    "evidence"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "name": { "type": "string" },
    "attribution": {
      "type": ["string", "null"],
      "description": "Who formalized it. null = folk/unattributable."
    },
    "status": {
      "enum": ["draft", "verified"],
      "description": "draft = citations unverified by a human. Nothing ships verified without L4 human commit."
    },
    "intensity_model": {
      "enum": [
        "daniels-vdot",
        "pct_hrmax",
        "pct_hrr",
        "pct_vo2max",
        "pct_cs",
        "rpe_10",
        "lactate_mmol",
        "race_pace_ref"
      ],
      "description": "The system's anchor. switching_cost.anchor_change is derived from this, therefore machine-verifiable."
    },
    "bet": {
      "$ref": "#/$defs/i18n",
      "description": "One sentence, what it wagers that others do not. Length and sentence count are enforced in validate.mjs. Longer than a sentence is philosophy, and there is a field for that."
    },
    "philosophy": { "$ref": "#/$defs/i18n" },
    "commitment": { "$ref": "#/$defs/commitment" },
    "switching_cost": { "type": "array", "items": { "$ref": "#/$defs/switching_cost" } },
    "distribution": { "$ref": "#/$defs/distribution" },
    "volume_caps": { "type": "array", "items": { "$ref": "#/$defs/volume_cap" } },
    "phases": { "type": "array", "items": { "$ref": "#/$defs/phase" } },
    "evidence": { "$ref": "#/$defs/evidence" },
    "caveats": { "type": "array", "items": { "$ref": "#/$defs/i18n" } }
  },

  "$defs": {
    "i18n": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ko", "en"],
      "properties": { "ko": { "type": "string" }, "en": { "type": "string" } }
    },

    "count": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": { "type": "integer", "minimum": 1 },
        "min": { "type": "integer", "minimum": 1 },
        "max": { "type": "integer", "minimum": 1 }
      },
      "oneOf": [{ "required": ["value"] }, { "required": ["min", "max"] }]
    },

    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tier"],
      "properties": {
        "tier": { "enum": ["consensus", "plausible", "tradition"] },
        "cite": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "note": { "$ref": "#/$defs/i18n" }
      },
      "allOf": [
        {
          "if": {
            "required": ["tier"],
            "properties": { "tier": { "enum": ["consensus", "plausible"] } }
          },
          "then": { "required": ["cite"] }
        },
        {
          "if": { "required": ["tier"], "properties": { "tier": { "const": "tradition" } } },
          "then": { "not": { "required": ["cite"] } }
        }
      ]
    },

    "commitment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessions_per_week"],
      "description": "The first filter for someone shopping methods: can I even run this? Rarely stated by the systems themselves.",
      "properties": {
        "sessions_per_week": { "$ref": "#/$defs/count" },
        "min_weekly_km": { "type": "number", "exclusiveMinimum": 0 },
        "plan_length_weeks": { "$ref": "#/$defs/count" },
        "requires_track": { "type": "boolean" },
        "note": { "$ref": "#/$defs/i18n" }
      }
    },

    "switching_cost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "anchor_change", "silent", "note"],
      "description": "What breaks when you arrive here from another system. anchor_change is derivable from both systems' intensity_model and is checked in validate.mjs.",
      "properties": {
        "from": { "type": "string", "description": "A system id. Never this system's own id." },
        "anchor_change": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+ -> [a-z0-9_-]+$",
          "description": "'<from.intensity_model> -> <this.intensity_model>'. Machine-verified, not authored freely."
        },
        "silent": {
          "type": "boolean",
          "description": "true = a term survives the switch while its meaning changes. The dangerous case, because nothing signals it."
        },
        "note": { "$ref": "#/$defs/i18n" }
      }
    },

    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "evidence"],
      "properties": {
        "model": { "enum": ["pyramidal", "polarized", "threshold", "unstructured"] },
        "zones": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "pct_sessions"],
            "properties": {
              "label": { "type": "string" },
              "pct_sessions": { "type": "number", "minimum": 0, "maximum": 100 }
            }
          },
          "description": "Percent of SESSIONS, not time. The confusion is common enough to name in the field description."
        },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },

    "volume_cap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zone", "rule", "evidence"],
      "properties": {
        "zone": { "type": "string" },
        "max_pct_weekly": { "type": "number", "exclusiveMinimum": 0, "maximum": 100 },
        "max_km": { "type": "number", "exclusiveMinimum": 0 },
        "rule": { "$ref": "#/$defs/i18n" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },

    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "emphasis"],
      "properties": {
        "name": { "enum": ["base", "build", "peak", "taper", "offseason"] },
        "emphasis": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Workout ids. Referential integrity checked in validate.mjs."
        },
        "note": { "$ref": "#/$defs/i18n" }
      }
    }
  }
}
